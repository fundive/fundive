{
  "name": "fundive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "fundive": "cli/index.js"
  },
  "exports": {
    "./config": "./src/config/define.ts",
    "./vite": "./src/vite/index.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "npm run build && dotenv -e .env.local -- wrangler deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test:all": "vitest run",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "db:link": "dotenv -e .env.local -- sh -c 'supabase link --project-ref \"$SUPABASE_PROJECT_REF\" --password \"$SUPABASE_DB_PASSWORD\"'",
    "db:pull": "dotenv -e .env.local -- sh -c 'supabase db pull --password \"$SUPABASE_DB_PASSWORD\"'",
    "db:push": "dotenv -e .env.local -- sh -c 'supabase db push --password \"$SUPABASE_DB_PASSWORD\"'",
    "db:dump-data": "dotenv -e .env.local -- sh -c 'supabase db dump --data-only --schema auth,public --exclude public.DiveTravel --exclude public.cancellation_policies --exclude public.cert_levels --exclude public.dive_sites --password \"$SUPABASE_DB_PASSWORD\" -f supabase/seed.sql'",
    "functions:deploy": "dotenv -e .env.local -- sh -c 'supabase functions deploy --project-ref \"$SUPABASE_PROJECT_REF\"'"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/supabase-js": "^2.110.1",
    "date-fns": "^4.4.0",
    "fflate": "^0.8.3",
    "heic2any": "^0.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
