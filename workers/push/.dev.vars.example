# Copy to .dev.vars for `wrangler dev --test-scheduled`. Never commit secrets.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
VAPID_PUBLIC_KEY=BKd0N2Xg...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:you@example.com
ADMIN_TRIGGER_SECRET=pick-something-random
# Optional. /admin-broadcast also needs the anon key so it can verify the
# caller's role via their JWT.
SUPABASE_ANON_KEY=eyJhbGciOi...
# Optional. When set, /admin-broadcast POSTs `{title, body}` JSON here too
# (e.g. a LINE Messaging API relay or a third-party automation endpoint).
BROADCAST_WEBHOOK_URL=
