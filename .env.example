# FunDive deployment environment — copy to `.env.local` and fill in. NEVER commit it.
# `.env.local` is what the make/npm scripts read. Secrets live only here (and your
# CI secret store), never in the committed repo.

# ── Client build (baked into the bundle by Vite) ─────────────────────────────
# Required — the app can't boot / guest signup dead-ends without these:
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
# Optional — push notifications stay off if unset:
VITE_VAPID_PUBLIC_KEY=your-web-push-vapid-public-key
VITE_PUSH_WORKER_URL=https://fundive-push.YOUR-SUBDOMAIN.workers.dev

# ── Supabase (migrations + verify, via the fundive CLI) ──────────────────────
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_ACCESS_TOKEN=your-personal-access-token
SUPABASE_POOLER_HOST=aws-x-region.pooler.supabase.com

# ── Cloudflare (deploy, via the fundive CLI / wrangler) ──────────────────────
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# ── Push worker secrets (set via `wrangler secret put` in workers/push) ──────
VAPID_PUBLIC_KEY=your-web-push-vapid-public-key
VAPID_PRIVATE_KEY=your-web-push-vapid-private-key   # server-side only, never in the bundle
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key      # server-side only, bypasses RLS
ADMIN_TRIGGER_SECRET=a-random-bearer-token
# Optional:
BROADCAST_WEBHOOK_URL=

# ── Supabase Edge Function secrets (set via `supabase secrets set`) ──────────
GMAIL_USER=you@example.com
GMAIL_APP_PASSWORD=your-gmail-app-password
TURNSTILE_SECRET=your-cloudflare-turnstile-secret
